{
  "name": "@ai-nexus/mcp-server",
  "version": "1.0.0",
  "description": "AI Nexus MCP Server - Aggregates 67 AI models + 60+ enterprise systems into a unified MCP interface",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js --transport stdio",
    "start:sse": "node dist/server.js --transport sse --port 3100",
    "lint": "eslint src/",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "enterprise",
    "integration"
  ],
  "author": "AI Nexus",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.47.10",
    "express": "^4.21.0",
    "openai": "^4.52.7",
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/generative-ai": "^0.15.0",
    "groq-sdk": "^0.5.0",
    "cohere-ai": "^7.10.0",
    "zod": "^3.23.8",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
