{
  "name": "@velanova/tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node ../node_modules/jest/bin/jest.js",
    "test:unit": "node ../node_modules/jest/bin/jest.js --testPathPattern='(services|middleware|contexts|hooks|components)\\.test\\.'",
    "test:integration": "node ../node_modules/jest/bin/jest.js --testPathPattern='(routes|flows|api)\\.test\\.'",
    "test:express": "node ../node_modules/jest/bin/jest.js --testPathPattern='express-api/'",
    "test:desktop": "node ../node_modules/jest/bin/jest.js --testPathPattern='desktop-app/'",
    "test:admin": "node ../node_modules/jest/bin/jest.js --testPathPattern='admin-dashboard/'",
    "test:landing": "node ../node_modules/jest/bin/jest.js --testPathPattern='landing-site/'",
    "test:watch": "node ../node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node ../node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node ../node_modules/jest/bin/jest.js --ci --coverage --reporters=default --reporters=jest-junit"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  }
}
