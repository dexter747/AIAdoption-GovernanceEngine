# Express API Server Environment Variables

# Server Configuration
PORT=5500
NODE_ENV=development

# Database (shared with Next.js apps)
DATABASE_URL=postgresql://user:password@localhost:5432/ainexus
MONGODB_URI=mongodb://localhost:27017/ainexus-logs

# JWT Secret for License Keys
LICENSE_JWT_SECRET=your-license-secret-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# API Keys (if needed)
INTERNAL_API_KEY=your-internal-api-key
