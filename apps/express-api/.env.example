# Backend Environment Variables - Velanova
# Copy this to .env and fill in your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5500
API_VERSION=v1

# =============================================================================
# DATABASE - SUPABASE (Primary PostgreSQL Database)
# =============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://lwounfzhkuuqvgkvwxvt.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# Direct PostgreSQL Connection (if needed for migrations)
DATABASE_URL=postgresql://postgres:[password]@db.lwounfzhkuuqvgkvwxvt.supabase.co:5432/postgres

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
LICENSE_JWT_SECRET=your-license-signing-secret-key-here
ENCRYPTION_KEY=your-aes-256-encryption-key-32-bytes-base64

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5199

# =============================================================================
# AI MODEL PROVIDERS - API KEYS
# =============================================================================

# --- OpenAI (GPT-4, GPT-3.5, GPT-4 Turbo) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxx  # Optional

# --- Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, Claude 3 Haiku) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google AI (Gemini 2.0 Flash, Gemini 1.5 Pro) ---
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_AI_PROJECT_ID=your-gcp-project-id  # Optional for Vertex AI

# --- Cohere (Command R+, Command R) ---
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mistral AI (Mistral Large, Mistral Medium) ---
# Get from: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (Llama 3, Mixtral - Fast Inference) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Perplexity AI (Sonar, Sonar Pro) ---
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- DeepSeek (DeepSeek Coder, DeepSeek Chat) ---
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Together AI (Various Open Source Models) ---
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Replicate (Stable Diffusion, LLama, etc.) ---
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- HuggingFace (Open Source Models) ---
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenRouter (Access to multiple models via one API) ---
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Azure OpenAI (Enterprise OpenAI) ---
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-turbo

# --- AWS Bedrock (Claude, Llama via AWS) ---
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# =============================================================================
# PAYMENT PROVIDERS
# =============================================================================

# --- Dodo Payments (Primary) ---
DODO_API_KEY=dodo_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DODO_SECRET_KEY=dodo_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- PayPal (Fallback) ---
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_MODE=sandbox  # or 'live'
PAYPAL_WEBHOOK_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Razorpay (India) ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# EMAIL SERVICE
# =============================================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@velanova.com
# Or Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/0000000
DATADOG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# REDIS & RATE LIMITING
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_AI_PROVIDERS=openai,anthropic,google,cohere,mistral,groq,perplexity
TRIAL_PERIOD_DAYS=14
MAX_DEVICES_PER_LICENSE=5
