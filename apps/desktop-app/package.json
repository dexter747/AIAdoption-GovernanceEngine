{
  "name": "desktop-app",
  "version": "1.0.1",
  "private": true,
  "main": "./electron.js",
  "description": "Velanova Desktop Application - Electron + React + TypeScript",
  "author": "Velanova Team",
  "scripts": {
    "dev": "pnpm run build:preload && concurrently \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite --port 5199 --strictPort",
    "dev:electron": "wait-on http://localhost:5199 && cross-env NODE_ENV=development VITE_DEV_PORT=5199 electron .",
    "dev:main": "tsx watch src/main/index.ts",
    "build": "pnpm run build:renderer && pnpm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc src/main/preload.ts --outDir dist/main --module commonjs --target ES2020 --esModuleInterop --skipLibCheck",
    "build:all": "pnpm run build && electron-builder",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:win": "pnpm run build && electron-builder --win",
    "build:linux": "pnpm run build && electron-builder --linux",
    "build:all-platforms": "pnpm run build && electron-builder --mac --win --linux",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.14.0",
    "@azure/openai": "^1.0.0-beta.11",
    "@google/generative-ai": "^0.2.1",
    "@mistralai/mistralai": "^0.1.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "@sap/hana-client": "^2.19.21",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.6.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cohere-ai": "^7.7.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "groq-sdk": "^0.3.0",
    "html2canvas": "^1.4.1",
    "jsforce": "^2.0.0-beta.29",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "keytar": "^7.9.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.309.0",
    "mongodb": "^6.3.0",
    "mysql2": "^3.7.1",
    "ollama": "^0.4.2",
    "openai": "^4.24.1",
    "oracledb": "^6.3.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.21.3",
    "recharts": "^2.10.4",
    "sql.js": "^1.10.3",
    "tailwind-merge": "^2.2.0",
    "tedious": "^16.7.1",
    "zustand": "^4.4.7"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@shared/types": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.1.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "framer-motion": "^11.18.2",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.33",
    "react-markdown": "^9.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.velanova.desktop",
    "productName": "Velanova",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron.js",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../packages/mcp-servers",
        "to": "mcp-servers",
        "filter": [
          "*/dist/**/*",
          "*/package.json"
        ]
      }
    ],
    "protocols": [
      {
        "name": "Velanova Protocol",
        "schemes": [
          "velanova"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Nexolve-Technologies-India",
      "repo": "AIAdoption-GovernanceEngine"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Velanova Protocol",
            "CFBundleURLSchemes": [
              "velanova"
            ]
          }
        ]
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Velanova Inc.",
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "mimeTypes": [
        "x-scheme-handler/velanova"
      ],
      "desktop": {
        "StartupNotify": "true",
        "Terminal": "false"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "license": "../../LICENSE"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
