# Admin Dashboard Environment Variables

# App URL (update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Database (Prisma - PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ainexus"

# MongoDB (for logs and analytics)
MONGODB_URI="mongodb://localhost:27017/ainexus-logs"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth (same credentials as landing-site, different redirect URI)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# Admin Access
ADMIN_EMAIL="admin@domain.com"
ADMIN_PASSWORD_HASH="your-hashed-password"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="admin@domain.com"

# API Endpoints
API_BASE_URL="https://api.domain.com"
