# Landing Site Environment Variables

# Database (Prisma - PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ainexus"

# MongoDB (for logs and analytics)
MONGODB_URI="mongodb://localhost:27017/ainexus-logs"

# NextAuth
NEXTAUTH_URL="https://domain.com"
NEXTAUTH_SECRET="your-secret-key-here"

# Payment Gateways
# Dodo Payments
DODO_PAYMENTS_API_KEY="your-dodo-api-key"
DODO_PAYMENTS_SECRET="your-dodo-secret"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox" # or "production"

# Razorpay (India)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@domain.com"

# License Key Generation
LICENSE_JWT_SECRET="your-license-secret-key"

# API Endpoints
API_BASE_URL="https://api.domain.com"
