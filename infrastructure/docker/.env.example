# Velanova MCP Farm Environment Configuration
# Copy this to .env and fill in your values

# ============================================================================
# CORE CONFIGURATION
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================================================
# SUPABASE (Required)
# ============================================================================
SUPABASE_URL=https://lwounfzhkuuqvgkvwxvt.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# AI PROVIDER API KEYS
# ============================================================================
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
GOOGLE_AI_API_KEY=...

# Groq (Fast inference)
GROQ_API_KEY=gsk_...

# Cohere
COHERE_API_KEY=...

# Mistral AI
MISTRAL_API_KEY=...

# Together AI
TOGETHER_API_KEY=...

# ============================================================================
# DATABASE CONNECTIONS
# ============================================================================
# PostgreSQL
POSTGRES_URL=postgresql://user:password@localhost:5432/database

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=mydb

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mydb

# Redis
REDIS_URL=redis://localhost:6379

# ============================================================================
# VERSION CONTROL
# ============================================================================
# GitHub
GITHUB_TOKEN=ghp_...

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-...

# ============================================================================
# COLLABORATION TOOLS
# ============================================================================
# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T...

# Jira
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=...

# ============================================================================
# CRM/ERP SYSTEMS
# ============================================================================
# Salesforce
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=...
SF_CLIENT_SECRET=...
SF_USERNAME=...
SF_PASSWORD=...
SF_SECURITY_TOKEN=...

# ServiceNow
SERVICENOW_INSTANCE=your-instance.service-now.com
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=...

# ============================================================================
# ENTERPRISE SYSTEMS (Custom MCP Servers)
# ============================================================================
# SAP S/4HANA
SAP_HOST=your-sap-server.com
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=sapuser
SAP_PASSWORD=...
SAP_LANG=EN

# Epic FHIR (Healthcare)
EPIC_BASE_URL=https://your-epic-instance.com/fhir/r4
EPIC_CLIENT_ID=...
EPIC_CLIENT_SECRET=...
EPIC_REDIRECT_URI=http://localhost:3000/callback
ENABLE_PHI_REDACTION=true

# AS/400 (IBM i)
AS400_HOST=your-as400.com
AS400_USER=...
AS400_PASSWORD=...
AS400_LIBRARY=QGPL

# Workday
WORKDAY_TENANT=your-tenant
WORKDAY_CLIENT_ID=...
WORKDAY_CLIENT_SECRET=...

# ============================================================================
# CLOUD PROVIDERS
# ============================================================================
# AWS
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Azure
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================================
# INFRASTRUCTURE
# ============================================================================
# Terraform Cloud
TF_CLOUD_TOKEN=...

# Kubernetes (uses ~/.kube/config by default)
# KUBECONFIG=/path/to/kubeconfig
